# Скопируйте этот файл в server/.env и подставьте свои значения.
# Сервер Bun читает переменные при запуске (bun run dev).

# --- Redis / Valkey (при локальном API и контейнере compose: порт 6379 на хосте)
VALKEY_HOST=localhost
VALKEY_PORT=6379
VALKEY_PASSWORD=change-me

# --- PostgreSQL ---
# Если API запускается на машине-хосте, а БД — в Docker, хост почти всегда localhost,
# пароль/user/db должны совпадать с POSTGRES_* в корневом .env для compose.
#
# Формат: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://coffee:change-me@localhost:5433/coffee

# Если бы API тоже крутился внутри compose-сети, вместо localhost был бы hostname сервиса: postgres.
